{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Polyglot",
  "version": "0.1.0",
  "identifier": "com.lotfb86.polyglot",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Polyglot",
        "label": "main",
        "width": 400,
        "height": 720,
        "minWidth": 360,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/audiotee"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
